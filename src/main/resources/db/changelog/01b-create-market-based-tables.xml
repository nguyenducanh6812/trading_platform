    <!-- Market-Based Price Data Tables            -->
    <!-- ========================================= -->

    <changeSet id="001b-001-create-spot-price-data-table" author="trading-platform-team">
        <comment>Create spot_price_data table for SPOT market OHLCV price data</comment>

        <createTable schemaName="trading_platform" tableName="spot_price_data">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_spot_price_data"/>
            </column>
            <column name="symbol" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="open_price" type="DECIMAL(26,16)">
                <constraints nullable="false"/>
            </column>
            <column name="high_price" type="DECIMAL(26,16)">
                <constraints nullable="false"/>
            </column>
            <column name="low_price" type="DECIMAL(26,16)">
                <constraints nullable="false"/>
            </column>
            <column name="close_price" type="DECIMAL(26,16)">
                <constraints nullable="false"/>
            </column>
            <column name="volume" type="DECIMAL(32,16)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(10)" defaultValue="USD">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint
            schemaName="trading_platform"
            tableName="spot_price_data"
            columnNames="symbol, timestamp"
            constraintName="uk_spot_price_symbol_timestamp"/>

        <createIndex schemaName="trading_platform" tableName="spot_price_data" indexName="idx_spot_price_symbol">
            <column name="symbol"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="spot_price_data" indexName="idx_spot_price_timestamp">
            <column name="timestamp"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="spot_price_data" indexName="idx_spot_price_symbol_timestamp">
            <column name="symbol"/>
            <column name="timestamp" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="trading_platform" tableName="spot_price_data" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

