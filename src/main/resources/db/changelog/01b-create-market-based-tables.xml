    <changeSet id="001b-009-create-spot-expected-return-prediction-table" author="trading-platform-team">
        <comment>Create spot_expected_return_prediction table for SPOT market predictions</comment>

        <createTable schemaName="trading_platform" tableName="spot_expected_return_prediction">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_spot_expected_return_prediction"/>
            </column>
            <column name="symbol" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="execution_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="forecast_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="expected_return" type="DECIMAL(23,16)">
                <constraints nullable="false"/>
            </column>
            <column name="confidence_level" type="DECIMAL(20,16)">
                <constraints nullable="false"/>
            </column>
            <column name="model_version" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="prediction_status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="summary" type="TEXT"/>
            <column name="data_points_used" type="INTEGER"/>
            <column name="ar_order" type="INTEGER"/>
            <column name="mean_squared_error" type="DECIMAL(23,16)"/>
            <column name="standard_error" type="DECIMAL(23,16)"/>
            <column name="execution_time_ms" type="BIGINT"/>
            <column name="has_sufficient_quality" type="BOOLEAN"/>
            <column name="error_message" type="TEXT"/>
            <column name="predict_diff_oc" type="DECIMAL(23,16)"/>
            <column name="predict_oc" type="DECIMAL(23,16)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            schemaName="trading_platform"
            tableName="spot_expected_return_prediction"
            columnNames="symbol, forecast_date, model_version"
            constraintName="uk_spot_prediction_symbol_date_model"/>

        <createIndex schemaName="trading_platform" tableName="spot_expected_return_prediction" indexName="idx_spot_prediction_symbol">
            <column name="symbol"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="spot_expected_return_prediction" indexName="idx_spot_prediction_forecast_date">
            <column name="forecast_date"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="spot_expected_return_prediction" indexName="idx_spot_prediction_execution_id">
            <column name="execution_id"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="trading_platform" tableName="spot_expected_return_prediction" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

