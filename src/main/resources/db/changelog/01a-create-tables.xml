<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ========================================= -->
    <!-- Market Data Module Tables                 -->
    <!-- ========================================= -->

    <changeSet id="001a-create-markets-table" author="trading-platform-team">
        <comment>Create markets table for market reference data (SPOT, LINEAR, INVERSE, OPTION)</comment>

        <createTable schemaName="trading_platform" tableName="markets">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_markets"/>
            </column>
            <column name="code" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <createIndex schemaName="trading_platform" tableName="markets" indexName="idx_markets_code">
            <column name="code"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="trading_platform" tableName="markets" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

    <changeSet id="001b-populate-markets-table" author="trading-platform-team">
        <comment>Populate markets table with initial market types</comment>

        <insert schemaName="trading_platform" tableName="markets">
            <column name="code" value="SPOT"/>
            <column name="name" value="Spot Trading"/>
            <column name="description" value="Regular spot trading pairs"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert schemaName="trading_platform" tableName="markets">
            <column name="code" value="LINEAR"/>
            <column name="name" value="Linear Futures"/>
            <column name="description" value="USDT-margined perpetual contracts"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert schemaName="trading_platform" tableName="markets">
            <column name="code" value="INVERSE"/>
            <column name="name" value="Inverse Futures"/>
            <column name="description" value="Coin-margined perpetual contracts"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <insert schemaName="trading_platform" tableName="markets">
            <column name="code" value="OPTION"/>
            <column name="name" value="Options"/>
            <column name="description" value="Options contracts"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <rollback>
            <delete schemaName="trading_platform" tableName="markets"/>
        </rollback>
    </changeSet>

    <changeSet id="001c-create-market-instruments-table" author="trading-platform-team">
        <comment>Create market_instruments table for storing trading instrument metadata</comment>

        <createTable schemaName="trading_platform" tableName="market_instruments">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_market_instruments"/>
            </column>
            <column name="symbol" type="VARCHAR(30)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="contract_type" type="VARCHAR(30)"/>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="base_currency" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="quote_currency" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="settle_coin" type="VARCHAR(30)"/>
            <column name="launch_time" type="BIGINT"/>
            <column name="delivery_time" type="BIGINT"/>
            <column name="min_leverage" type="DECIMAL(10,2)"/>
            <column name="max_leverage" type="DECIMAL(10,2)"/>
            <column name="min_order_qty" type="DECIMAL(20,8)"/>
            <column name="max_order_qty" type="DECIMAL(20,8)"/>
            <column name="qty_step" type="DECIMAL(20,8)"/>
            <column name="tick_size" type="DECIMAL(20,8)"/>
            <column name="data_point_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="quality_score" type="DOUBLE PRECISION"/>
            <column name="quality_level" type="VARCHAR(20)"/>
            <column name="data_source" type="VARCHAR(50)"/>
            <column name="market_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="first_trading_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <!-- Foreign key to markets table -->
        <addForeignKeyConstraint
            baseTableSchemaName="trading_platform"
            baseTableName="market_instruments"
            baseColumnNames="market_id"
            constraintName="fk_market_instruments_market"
            referencedTableSchemaName="trading_platform"
            referencedTableName="markets"
            referencedColumnNames="id"
            onDelete="RESTRICT"/>

        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instrument_symbol">
            <column name="symbol"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instrument_base_currency">
            <column name="base_currency"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instrument_quote_currency">
            <column name="quote_currency"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instruments_first_trading_date">
            <column name="first_trading_date"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instruments_market_id">
            <column name="market_id"/>
        </createIndex>
        <createIndex schemaName="trading_platform" tableName="market_instruments" indexName="idx_market_instruments_market_id_symbol">
            <column name="market_id"/>
            <column name="symbol"/>
        </createIndex>

        <rollback>
            <dropTable schemaName="trading_platform" tableName="market_instruments" cascadeConstraints="true"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
